---
import { string } from "astro:schema";

// SobreDinamico.astro
const {
  TituloNombre = string,
  ColorSobre = "bg-pink-600", 
  FotoUrl = string
} = Astro.props;

const path = ""; 
const imgBack = `${path}/EnvelopBack.webp`;
const imgFront = `${path}/EnvelopFront.webp`;
const imgFlap = `${path}/EnvelopFlap.webp`;
const imgSeal = `${path}/EnvelopSeal.webp`;
--- 

<!-- 1. Envolvemos todo en un wrapper para controlar el flujo -->
<div id="wrapper-seccion-sobre" class="relative w-full">
  <div id="contenedor-global-scroll" class="h-[300vh] w-full">
    
      <div id="panel-fijo" class="relative h-screen w-full flex flex-col items-center justify-end pb-24 md:justify-center overflow-hidden "
      style={`background-image: url('${FotoUrl}'); background-size: cover; background-position: 50% 30%;`}>
        
        <div id="efecto-oscuro" class="absolute inset-0 bg-black/20 backdrop-blur-md z-0"></div>
          
        <div id="contenedor-titulo" class="relative z-10">
            <h2 id="TituloPrincipal" class="opacity-0 translate-y-8 font-DancingScript text-8xl md:text-6xl lg:text-7xl text-center mb-8 text-white font-bold [text-shadow:_2px_4px_6px_rgb(0_0_0_/_50%)]">
              {TituloNombre}
            </h2>
        </div>
        
        <div class="relative z-10 w-[92%] max-w-[400px] aspect-[16/11] [perspective:1500px]" id="escena-3d">
            
            <div 
              class={`absolute inset-0 z-1 ${ColorSobre}`}
              style={`mask-image: url('${imgBack}'); -webkit-mask-image: url('${imgBack}'); mask-size: contain; mask-repeat: no-repeat; mask-position: center;`}
            >
              <img src={imgBack} class="w-full h-full object-contain mix-blend-multiply opacity-80" />
            </div>

            <div 
              id="tarjeta-invitacion" 
              class="absolute left-1/2 -translate-x-1/2 bg-white z-10 shadow-2xl overflow-hidden border-6 border-white rounded-lg"
              style="width: 60%; aspect-ratio: 9/16; top: -20%; transform: scale(0.4);" 
            >
              <img src={FotoUrl} class="w-full h-full object-cover" alt="Invitación" />
            </div>

            <div 
              class={`absolute inset-0 z-20 ${ColorSobre} drop-shadow-2xl`}
              style={`mask-image: url('${imgFront}'); -webkit-mask-image: url('${imgFront}'); mask-size: contain; mask-repeat: no-repeat; mask-position: center;`}
            >
              <img src={imgFront} class="w-full h-full object-contain mix-blend-multiply" />
            </div>

            <div 
              id="contenedor-solapa"
              class="absolute inset-0 z-30 [transform-origin:center_65px] [transform-style:preserve-3d]"
            >
              <div 
                class={`absolute inset-0 ${ColorSobre}`}
                style={`mask-image: url('${imgFlap}'); -webkit-mask-image: url('${imgFlap}'); mask-size: contain; mask-repeat: no-repeat; mask-position: center;`}
              >
                <img src={imgFlap} class="w-full h-full object-contain mix-blend-multiply" />
              </div>
              <img 
                src={imgSeal} 
                class="absolute left-1/2 -translate-x-1/2 bottom-[2%] w-24 h-24 object-contain z-40 drop-shadow-md"
              />
            </div>

        </div>

      </div>
    </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("load", () => {
    gsap.to("#TituloPrincipal", {
      opacity: 1,
      y: 0, // Devuelve el elemento a su posición original (quita el translate-y-8)
      duration: 1.5, // 1.5 segundos de duración
      ease: "power3.out", // Un frenado suave y elegante al final
      delay: 0.2 // Un pequeño respiro de 0.2s después de cargar antes de arrancar
    });
  });

  // Creamos el selector de medios (como las media queries pero para JS)
  let mm = gsap.matchMedia();

  mm.add({
    // Definimos nuestras condiciones
    isDesktop: "(min-width: 1024px)",
    isMobile: "(max-width: 1023px)"
  }, (context) => {                                       
    // Extraemos las condiciones para usarlas
    const { conditions } = context;

    if (!conditions) return; 

    const { isDesktop, isMobile } = conditions;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#contenedor-global-scroll",
        start: "top top",
        end: "bottom bottom",
        scrub: 1,
        pin: "#panel-fijo",
        pinSpacing: true,
        anticipatePin: 1,
      }
    });

    // --- ANIMACIÓN COMÚN (Solapa) ---
    tl.to("#contenedor-solapa", { 
      rotateX: 170, 
      duration: 1.2, 
      ease: "power2.inOut" 
    })
    .set("#tarjeta-invitacion", { zIndex: 50 });

    // --- ANIMACIÓN DIFERENCIADA (Extracción) ---
    tl.to("#tarjeta-invitacion", {
      // Si es PC sube poco (-10vh), si es Móvil sube mucho (-35vh)
      y: isDesktop ? "0vh" : "-35vh", 
      // Si es PC escala menos para que no tape todo
      scale: isDesktop ? 1.1 : 1.3, 
      duration: 1.5,
      ease: "power2.out"
    })
    .to({}, { duration: 1 });

    return () => {
      // Limpieza automática al cambiar de tamaño de pantalla
    };
  });
</script>